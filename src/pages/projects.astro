---
import CenteredLayout from "../layouts/CenteredLayout.astro";
import { SITE_TITLE } from "../consts";
import { Video, Shield, Dog, Camera, Github, ExternalLink, FileText, Cpu } from "lucide-react";

const projects = [
	{
		id: "ai-native-communication-os",
		data: {
			title: "AI Native Communication OS",
			description: "A specialized operating system layer for collaborative communication, featuring autonomous agent orchestration, ephemeral secret management, and AI-driven automation.",
			status: "Ongoing",
			year: "2026",
			icon: "cpu",
			github: "https://github.com/joynahid/wirestaq-site"
		}
	},
	{
		id: "vpn-infrastructure",
		data: {
			title: "Scalable Backend Infrastructure Powering a Commercial VPN Service with WireGuard Protocol",
			description: "High-performance backend infrastructure for commercial VPN service with automated server provisioning and load balancing.",
			status: "Completed",
			year: "2023",
			icon: "shield",
			notion: "https://notion.so/nahidscript/vpn-infrastructure"
		}
	}
];

const getIconColors = (icon: string) => {
	switch(icon) {
		case "dog": return "text-amber-400/60";
		case "camera": return "text-purple-400/60";
		case "video": return "text-blue-400/60";
		case "shield": return "text-green-400/60";
		case "cpu": return "text-blue-500/60";
		default: return "text-gray-400/50";
	}
};
---

<CenteredLayout title={`Things I Built - ${SITE_TITLE}`} description="Things I've built - from system tools to infrastructure projects">
	<section class="py">
		<p class="text-sm pb-4">
			A collection of projects I've worked on, ranging from system utilities to backend infrastructure solutions.
		</p>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
			{
				projects.map((project) => (
				<div class="flex flex-col p-4 rounded-lg border border-border/50 hover:border-border/80 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] transition-colors duration-200 cursor-default">
					<div class="flex items-start justify-between w-full mb-3">
						<div>
							{project.data.icon === "dog" && <Dog client:load className={`w-7 h-7 ${getIconColors("dog")}`} />}
							{project.data.icon === "camera" && <Camera client:load className={`w-7 h-7 ${getIconColors("camera")}`} />}
							{project.data.icon === "video" && <Video client:load className={`w-7 h-7 ${getIconColors("video")}`} />}
							{project.data.icon === "shield" && <Shield client:load className={`w-7 h-7 ${getIconColors("shield")}`} />}
							{project.data.icon === "cpu" && <Cpu client:load className={`w-7 h-7 ${getIconColors("cpu")}`} />}
						</div>
						<div class="flex gap-1">
							{project.data.github && (
								<button
									class="p-1.5 rounded-md hover:bg-secondary transition-colors"
									onclick={`window.open('${project.data.github}', '_blank')`}
									onpointerdown="event.stopPropagation()"
									title="View on GitHub"
								>
									<Github client:load className="w-4 h-4 text-muted-foreground hover:text-foreground transition-colors" />
								</button>
							)}
							{project.data.demo && (
								<button
									class="p-1.5 rounded-md hover:bg-secondary transition-colors"
									onclick={`window.open('${project.data.demo}', '_blank')`}
									onpointerdown="event.stopPropagation()"
									title="View demo"
								>
									<ExternalLink client:load className="w-4 h-4 text-muted-foreground hover:text-foreground transition-colors" />
								</button>
							)}
							{project.data.notion && (
								<button
									class="p-1.5 rounded-md hover:bg-secondary transition-colors"
									onclick={`window.open('${project.data.notion}', '_blank')`}
									onpointerdown="event.stopPropagation()"
									title="View in Notion"
								>
									<FileText client:load className="w-4 h-4 text-muted-foreground hover:text-foreground transition-colors" />
								</button>
							)}
						</div>
					</div>
					<h3 class="font-bold text-base leading-tight">
						{project.data.title}
					</h3>
					<p class="text-xs text-muted-foreground mt-2 leading-relaxed">
						{project.data.description}
					</p>
					<div class="flex items-center gap-2 mt-4">
						<span class:list={[
							"w-1.5 h-1.5 rounded-full shrink-0",
							project.data.status === "Ongoing" || project.data.status === "Active" ? "bg-green-400" : "bg-muted-foreground/40"
						]} />
						<span class="text-xs text-muted-foreground">
							{project.data.year} · {project.data.status}
						</span>
					</div>
				</div>
				))
			}
		</div>
	</section>
</CenteredLayout>
